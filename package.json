{
  "name": "nurseholic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --open /admin.html",
    "build": "vite build",
    "build:admin": "vite build --mode admin && node scripts/post-admin-build.mjs",
    "preview": "vite preview",
    "preview:admin": "vite preview --outDir dist-admin",
    "deploy:admin": "npm run build:admin && npx vercel --cwd dist-admin deploy --prod --yes",
    "deploy:check": "vite build && vite preview --host",
    "generate:content": "node scripts/generate.js",
    "test": "node scripts/run-tests.mjs"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0"
  }
}
