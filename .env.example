# Copy this file to `.env` and fill in your Supabase credentials.
# Find these values in your Supabase project: Settings -> API.
#
# The publishable (anon) key is designed to be public. Security is
# enforced server-side by Postgres Row-Level Security policies.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Session 5: Web Push (optional) ──────────────────────────────────
# Generate a VAPID key pair once with:  npx web-push generate-vapid-keys
#
# CLIENT (inlined by Vite at build time — must be VITE_-prefixed):
VITE_VAPID_PUBLIC_KEY=
#
# SERVER (Vercel serverless functions only — do NOT prefix with VITE_):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
#
# KV_REST_API_URL and KV_REST_API_TOKEN are added automatically when you
# attach a Vercel KV (Upstash Redis) store to the project — no manual entry.
