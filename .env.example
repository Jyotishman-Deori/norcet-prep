# Copy this file to `.env` and fill in your Supabase credentials.
# Find these values in your Supabase project: Settings -> API.
#
# The publishable (anon) key is designed to be public. Security is
# enforced server-side by Postgres Row-Level Security policies.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Session 5: Web Push (optional) ──────────────────────────────────
# Generate a VAPID key pair once with:  npx web-push generate-vapid-keys
#
# CLIENT (inlined by Vite at build time — must be VITE_-prefixed):
VITE_VAPID_PUBLIC_KEY=
#
# SERVER (Vercel serverless functions only — do NOT prefix with VITE_):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
#
# KV_REST_API_URL and KV_REST_API_TOKEN are added automatically when you
# attach a Vercel KV (Upstash Redis) store to the project — no manual entry.

# -- Umami Cloud analytics (free tier) ----------------------------------------
# Website ID (token) from the Umami dashboard. Leave BLANK to ship no analytics
# script at all (src/lib/umami.js is a no-op when this is empty).
VITE_UMAMI_WEBSITE_ID=
# Script source. Defaults to Umami Cloud free tier when blank; only set this if
# you self-host Umami.
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# -- Cloudflare Turnstile (free CAPTCHA) --------------------------------------
# PUBLIC site key for the widget (it ships in the client bundle by design).
# Leave BLANK to disable the widget (src/ui/turnstile.jsx renders nothing and
# the server fail-opens to match).
VITE_TURNSTILE_SITE_KEY=

# =====================================================================
# SERVER-ONLY SECRET (never commit; NOT a VITE_ var):
#   TURNSTILE_SECRET_KEY -- Cloudflare Turnstile secret, verified inside the
#   Supabase auth-secure Edge Function. Set with:
#     supabase secrets set TURNSTILE_SECRET_KEY="..."
#     supabase functions deploy auth-secure --no-verify-jwt
#   CAPTCHA is only ENFORCED once this is set.
# =====================================================================
# -- AI content generator (LOCAL script only -- scripts/generate.js) -----------
# Used ONLY by `npm run generate:content`, never by the shipped app. Keep these
# OUT of the client bundle (no VITE_ prefix) and out of git.
GEMINI_API_KEY=
# Optional: override the Gemini model (default is a current free-tier Flash model).
# GEMINI_MODEL=gemini-2.5-flash
# Server-side Supabase access for the generator + the content-staging broker.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
