# Copy this file to `.env` and fill in your Supabase credentials.
# Find these values in your Supabase project: Settings -> API.
#
# The publishable (anon) key is designed to be public. Security is
# enforced server-side by Postgres Row-Level Security policies.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
