# =====================================================================
# .env.development.example — TEMPLATE for the local-only .env.development.
#
# PURPOSE: `npm run dev` / `npm run dev:admin` must talk to the free-tier
# nurseholic-dev Supabase project, NEVER to production. Vite loads
# .env.development (mode "development") with priority over .env, and NO build
# (vite build, --mode admin, npm test) ever reads it.
#
# SETUP: copy this file to `.env.development`, fill in the two dev-project
# values (Supabase dashboard -> nurseholic-dev -> Settings -> API), done.
# The full dev-project runbook is docs/dev-environment.md.
#
# RULES:
#  - .env.development stays GITIGNORED (no keys in the repo, ever).
#  - PUBLIC dev values only. Secrets belong in .env (ignored) and in
#    Supabase secrets, never here and never in this example.
#  - Do NOT put production values in .env.development. If the file is
#    missing, the app shows a red LIVE DATA warning on every dev serve.
# =====================================================================

# The nurseholic-dev Supabase project (NOT production):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile ALWAYS-PASSES test sitekey (published by Cloudflare,
# not a secret). The dev project's auth-secure uses the matching test secret.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Powers the 'DEV DATA' badge; its absence on a dev serve = LIVE DATA warning.
VITE_ENV_LABEL=dev
